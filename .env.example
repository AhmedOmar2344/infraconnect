# Copy this file to .env and fill in real values.
# Never commit the real .env file — see .gitignore.

PORT=3000
NODE_ENV=development

# Generate a new random value — do NOT reuse this example.
# e.g. run:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_random_64_char_hex_string
JWT_EXPIRES_IN=8h

# Neon Postgres connection string.
# Get this from: Vercel dashboard → Storage → your Neon database → Connection String
# (or Neon's own dashboard if you created the database directly on neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# SMTP (for contact form / quote notification emails)
# For Gmail, use an App Password — not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
NOTIFY_EMAIL=info@yourdomain.com

# First admin account, created automatically on first run
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=choose_a_strong_password

BASE_URL=http://localhost:3000

# Comma-separated list of origins allowed to call the API (SEC-04).
# Example for production: https://infraconnect24-7.com,https://www.infraconnect24-7.com
CORS_ORIGINS=http://localhost:3000

# For the admin panel's "AI Product Creator" feature. Get a free key at
# aistudio.google.com (no credit card required) — Gemini's free tier covers
# occasional admin use indefinitely (daily request quota + free monthly
# search grounding allowance).
GEMINI_API_KEY=your-gemini-api-key-here

# Second AI provider option for the AI Product Creator, alongside Gemini.
# Get a key at platform.deepseek.com. This can also be set via
# Admin -> API Console (Service: "DeepSeek", Key Label: "API Key") instead
# of an environment variable. NOTE: this project reads this specific
# variable name (not the more conventional DEEPSEEK_API_KEY) because
# that's the exact name already configured in Vercel for this project.
Infraconnect=your-deepseek-api-key-here

# What actually gives DeepSeek live web search (it has no native search of
# its own — this is used via function calling). Free key at tavily.com,
# 1,000 searches/month, no credit card. Can also be set via Admin -> API
# Console (Service: "Tavily", Key Label: "API Key") instead. Without this,
# DeepSeek still works, it just falls back to training-data-only answers.
TAVILY_API_KEY=your-tavily-api-key-here

# Third AI provider option for the AI Product Creator, alongside Gemini and
# DeepSeek. Get a key at z.ai or open.bigmodel.cn. Uses the same Tavily key
# above for its web search capability (also via function calling, same as
# DeepSeek). Can also be set via Admin -> API Console (Service: "GLM", Key
# Label: "API Key") instead. NOTE: this project reads this specific
# variable name (not GLM_API_KEY) because that's the exact name already
# configured in Vercel for this project — note the hyphen and period mean
# this can only be read via process.env['GLM-4.7'] bracket notation, not
# the usual process.env.GLM_API_KEY dot notation.
GLM-4.7=your-glm-api-key-here

# Fourth AI provider option for the AI Product Creator — a genuinely free,
# ongoing tier (no card required, no balance to run out, unlike DeepSeek
# and GLM). Recommended default for regular day-to-day use. Get a key at
# console.groq.com. Can also be set via Admin -> API Console
# (Service: "Groq", Key Label: "API Key") instead.
GROQ_API_KEY=your-groq-api-key-here

# Fifth AI provider option for the AI Product Creator — BazaarLink
# (bazaarlink.ai), an OpenAI-compatible multi-model gateway. Get a free key
# at bazaarlink.ai/free (no card required). Uses the same Tavily key above
# for web search (function calling), same as DeepSeek. Can also be set via
# Admin -> API Console (Service: "Bazaar", Key Label: "API Key") instead.
BAZAAR_API_KEY=your-bazaar-api-key-here

# Sixth AI provider option for the AI Product Creator — ChatGPT (OpenAI).
# Get a key at platform.openai.com/api-keys (paid — no free tier, unlike
# Groq/Bazaar). Uses the same Tavily key above for web search (function
# calling), same as DeepSeek and Bazaar. Can also be set via Admin -> API
# Console (Service: "ChatGPT", Key Label: "API Key") instead.
OPENAI_API_KEY=your-openai-api-key-here

# Protects the automated monthly analytics report endpoint from being
# triggered by random internet traffic. Vercel sends this as a Bearer
# token automatically when its Cron Job fires (see vercel.json) — set it
# to any random string of 16+ characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=your-random-secret-here

# Product image uploads (manual + AI-downloaded). Connect a Blob store at
# Vercel -> your project -> Storage -> Create -> Blob -- this auto-injects
# the token below into your Vercel environment variables, same pattern as
# the Neon Postgres integration. For local development, run
# `vercel env pull .env.development.local`, or copy the token manually from
# Vercel's dashboard (Storage -> your Blob store -> .env.local tab).
BLOB_READ_WRITE_TOKEN=your-blob-token-here

# Encrypts third-party API keys stored in the admin API Console (payment
# gateways, SMS providers, etc.) before saving to the database. Generate
# one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=your-64-char-hex-key-here

# Google Sign-In on the customer account page (/account). Optional — this
# can also be set via Admin -> API Console (Service: "Google OAuth", Key
# Label: "Client ID") instead, without touching environment variables at
# all. If both are set, this environment variable takes priority. Get this
# value from console.cloud.google.com/apis/credentials -> your OAuth 2.0
# Client ID. Only the Client ID goes here — the Client Secret is NOT used
# by this integration and should not be stored anywhere in this project.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
